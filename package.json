{
  "name": "signalk-tidal-currents",
  "version": "0.3.0",
  "description": "Tidal current predictions from GRIB2, UTCEF and harmonic data sources",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run build:webapp",
    "build:webapp": "npm --prefix webapp ci && npm --prefix webapp run build",
    "test": "tsc && node -e \"require('fs').rmSync('dist-test',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('test/fixtures','dist-test/fixtures',{recursive:true})\" && node --test \"dist-test/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-weather",
    "signalk-category-utility",
    "signalk-webapp",
    "signalk",
    "tides",
    "tidal-currents",
    "xtide",
    "opencpn",
    "harmonics",
    "grib",
    "grib2",
    "utcef"
  ],
  "signalk": {
    "displayName": "Tidal Currents",
    "appIcon": "icon.svg",
    "screenshots": [
      "./img/screenshot-list.png",
      "./img/screenshot-list-dark.png",
      "./img/screenshot-near-you.png",
      "./img/screenshot-map.png",
      "./img/screenshot-config.jpg"
    ],
    "webapp": {
      "name": "Tidal Currents Manager",
      "description": "Download Manager for tidal-current data (GRIB2, UTCEF, harmonic)",
      "location": "/plugins/signalk-tidal-currents/"
    }
  },
  "signalk-plugin-enabled-by-default": false,
  "author": "Marcel Verpaalen",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelrv/signalk-tidal-currents.git"
  },
  "bugs": {
    "url": "https://github.com/marcelrv/signalk-tidal-currents/issues"
  },
  "homepage": "https://github.com/marcelrv/signalk-tidal-currents#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "public",
    "img",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "jpeg2000": "^1.1.1"
  }
}
