{
  "name": "signalk-tidal-currents",
  "version": "0.2.0",
  "description": "Tidal current predictions from OpenCPN/XTide harmonic files (HARMONIC/HARMONIC.IDX) and GRIB2 current fields — publishes environment.current and a station/position/timeline REST API",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node -e \"require('fs').rmSync('dist-test',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('test/fixtures','dist-test/fixtures',{recursive:true})\" && node --test \"dist-test/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-weather",
    "signalk-category-utility",
    "signalk",
    "tides",
    "tidal-currents",
    "xtide",
    "opencpn",
    "harmonics",
    "grib",
    "grib2"
  ],
  "signalk": {
    "displayName": "Tidal Currents",
    "appIcon": "./img/icon.svg",
    "screenshots": [
      "./img/screenshot-config.jpg"
    ]
  },
  "signalk-plugin-enabled-by-default": false,
  "author": "Marcel Verpaalen",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelrv/signalk-tidal-currents.git"
  },
  "bugs": {
    "url": "https://github.com/marcelrv/signalk-tidal-currents/issues"
  },
  "homepage": "https://github.com/marcelrv/signalk-tidal-currents#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "img",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
